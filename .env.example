# Firebase Admin SDK Configuration
# Copy this file to .env.local and fill in your actual values
FIREBASE_PROJECT_ID=mount-rushmore-unit-85e78
FIREBASE_CLIENT_EMAIL=your-service-account-email@mount-rushmore-unit-85e78.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_ACTUAL_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Firebase Client Configuration (should already be in your .env.local)
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=mount-rushmore-unit-85e78.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=mount-rushmore-unit-85e78
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=mount-rushmore-unit-85e78.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# Admin Authentication
ADMIN_TOKEN=your_admin_token_here
